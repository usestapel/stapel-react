{
  "name": "stapel-react",
  "private": true,
  "version": "0.0.0",
  "description": "Stapel React monorepo: headless frontend pairs for Stapel backend modules",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/usestapel/stapel-react.git"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "size": "turbo run size",
    "ci": "turbo run lint test build",
    "gen:api": "node scripts/gen-api.mjs",
    "gen:api:check": "node scripts/gen-api.mjs && git diff --exit-code -- packages/core/src/generated/schema.ts",
    "gen:flows": "node scripts/gen-flows.mjs",
    "gen:flows:check": "node scripts/gen-flows.mjs && git diff --exit-code -- packages/auth-react/src/flows/generated",
    "gen": "pnpm gen:api && pnpm gen:flows",
    "gen:check": "pnpm gen:api:check && pnpm gen:flows:check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run ci && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@eslint/js": "^9.30.0",
    "eslint": "^9.30.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "openapi-typescript": "^7.13.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0"
  }
}
