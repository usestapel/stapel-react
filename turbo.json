{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "size": {
      "dependsOn": ["build"],
      "outputs": []
    }
  }
}
