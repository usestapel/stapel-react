{
  "name": "@stapel/shell-react",
  "version": "0.1.0",
  "description": "Scripted-fullstack navigation shell (Ф1 lib-side core): resolveNav merges installed pairs' nav-manifests + a project's override file into a nav tree (pure, no React), and the /default AppShell renders it as a responsive antd Layout (Sider desktop, Drawer phone/tablet) around a react-router <Outlet/>.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/usestapel/stapel-react.git",
    "directory": "packages/shell-react"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./default": {
      "types": "./dist/default/index.d.ts",
      "default": "./dist/default/index.js"
    },
    "./manifest": "./manifest.json",
    "./manifest.json": "./manifest.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "tsconfig.json",
    "README.md",
    "CHANGELOG.md",
    "manifest.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint .",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "name": "index — resolveNav must stay pure: no React, no antd, no react-router",
      "path": "dist/index.js",
      "limit": "2 KB"
    },
    {
      "name": "default — the antd + react-router chrome must stay out of the main bundle",
      "path": "dist/default/index.js",
      "limit": "12 KB"
    }
  ],
  "peerDependencies": {
    "@stapel/core": ">=0.6.2 <1.0.0",
    "@stapel/tokens-antd": ">=0.2.0",
    "antd": ">=5.20.0 <7",
    "react": ">=19",
    "react-router": ">=7.0.0 <8"
  },
  "peerDependenciesMeta": {
    "@stapel/tokens-antd": {
      "optional": true
    },
    "antd": {
      "optional": true
    },
    "react-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.2.0",
    "@stapel/core": "workspace:^",
    "@stapel/tokens": "workspace:^",
    "@stapel/tokens-antd": "workspace:^",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "antd": "^6.5.0",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.18.1",
    "size-limit": "^11.2.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
