{
  "name": "@stapel/tokens",
  "version": "0.1.0",
  "description": "Stapel design tokens: semantic colors (light/dark pairs), typography, spacing, radii, elevation, and the three breakpoints. TypeScript source of truth + generated CSS custom properties. Not components.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/usestapel/stapel-react.git",
    "directory": "packages/tokens"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "tsconfig.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/build-css.mjs",
    "test": "vitest run",
    "lint": "eslint .",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "4 KB"
    }
  ],
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.2.0",
    "size-limit": "^11.2.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
