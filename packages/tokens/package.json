{
  "name": "@stapel/tokens",
  "version": "0.1.0",
  "description": "Stapel design tokens: three-tier colour system (raw ramps → semantic core light/dark pairs → component tokens) generated from theme.json, plus typography, spacing, radii, elevation, and the three breakpoints. CSS custom properties + typed names + a vanilla-Tailwind bridge. Not components.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/usestapel/stapel-react.git",
    "directory": "packages/tokens"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./raw": {
      "types": "./dist/generated/raw.d.ts",
      "default": "./dist/generated/raw.js"
    },
    "./tokens.css": "./src/generated/tokens.css",
    "./tailwind.css": "./src/generated/tailwind.css",
    "./theme.default.json": "./theme.default.json",
    "./manifest.json": "./manifest.json",
    "./llms.txt": "./llms.txt",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "theme.default.json",
    "ramps.standard.json",
    "manifest.json",
    "llms.txt",
    "tsconfig.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsc -p tsconfig.demo.json && vitest run",
    "lint": "eslint .",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.2.0",
    "@stapel/showcase": "workspace:^",
    "@tailwindcss/cli": "^4.1.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "size-limit": "^11.2.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
