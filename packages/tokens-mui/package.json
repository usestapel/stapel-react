{
  "name": "@stapel/tokens-mui",
  "version": "0.2.0",
  "description": "Token bridge (§68 neutral colour-role dictionary; frontend-guidelines §2.4, §38 T3): projects @stapel/tokens' roles (surface, brand, text-muted, success-bg, ...) onto a Material UI theme. `toMuiTheme(mode)` → a MUI Theme (createTheme). Pure function reading the same `colors` object as @stapel/tokens-antd, so they cannot diverge. Not components.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/usestapel/stapel-react.git",
    "directory": "packages/tokens-mui"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "tsconfig.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint .",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "3 KB"
    }
  ],
  "peerDependencies": {
    "@mui/material": ">=5.15.0 <8"
  },
  "dependencies": {
    "@stapel/tokens": "workspace:^"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/material": "^7.3.0",
    "@size-limit/preset-small-lib": "^11.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "size-limit": "^11.2.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
